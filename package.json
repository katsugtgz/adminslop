{
  "name": "eduadmin-pro-premium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "db:seed": "tsx src/db/seed/cli.ts",
    "db:seed:scrape": "node src/db/seed/scrape-soal.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
