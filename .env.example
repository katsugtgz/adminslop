# ─────────────────────────────────────────────────────────────────────
# WorkOS AuthKit — environment variables
# ─────────────────────────────────────────────────────────────────────
# Copy to `.env` and fill real values. NEVER commit real secrets.
# `.env` is gitignored. Use the WorkOS sandbox environment for development.
#
# Get these from the WorkOS Dashboard (sandbox env):
#   https://dashboard.workos.com  →  your sandbox environment

# Server-only API key (sk_test_* in sandbox). NEVER expose to the browser,
# NEXT_PUBLIC_*, logs, or client bundles.
WORKOS_API_KEY=

# Public client ID for the environment (safe to expose client-side).
WORKOS_CLIENT_ID=

# Secret used to seal the AuthKit session cookie. Generate with:
#   openssl rand -base64 48
# Must be stable across restarts or sessions invalidate. Server-only.
WORKOS_COOKIE_PASSWORD=

# (Optional) Set during initial environment provisioning, then removed.
# WORKOS_CLAIM_TOKEN=

# AuthKit redirect URI / homepage (local dev defaults shown).
# These are typically configured in the WorkOS dashboard, not required here.
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─────────────────────────────────────────────────────────────────────
# Supabase / Postgres (DB + RLS only; NO Supabase Auth)
# ─────────────────────────────────────────────────────────────────────
# Two roles: a superuser/owner for migrations, and a non-superuser app role
# (RLS-enforced). `npm run db:up` provisions both via docker/init.sql.
#
# App role (non-superuser) — RLS enforced here.
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/eduadmin
#
# Privileged role (superuser) — used only by the migrator.
DATABASE_MIGRATOR_URL=postgresql://postgres:postgres@localhost:5432/eduadmin
